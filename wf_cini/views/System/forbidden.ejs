<!DOCTYPE html>
<html lang="pt-br">
<head>
  <%- include('System/headIncludes.ejs') %>
  <title><%= pageTitle %> | CINI</title>
</head>
<body>
  <div class="layout-container">
    <div class="main-content" style="margin-left:56px;">
      <div class="content">
        <div class="card" style="max-width:820px; margin:48px auto; text-align:center;">
          <div class="card-body">
            <div class="error-icon mb-3">
              <i class="fas fa-exclamation-triangle fa-4x text-warning"></i>
            </div>
            <h2><%= pageTitle %></h2>
            <p class="text-muted"><%= pageDescription %></p>
            <div class="mt-4">
              <a href="/processos" class="btn btn-primary me-2">Voltar para a aba de Processos</a>
              <a href="javascript:history.back()" class="btn btn-secondary">Voltar</a>
            </div>
            <div class="mt-3 text-muted small">
              Se acreditar que isso é um erro, contate o administrador do sistema.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%- include('System/bodyIncludes.ejs') %>
</body>
</html>
