<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Processos' }]
}) %>

<%
  const __fmtDateTime = (typeof fmtDateTime === 'function')
    ? fmtDateTime
    : function (value) {
        if (!value) return '-';
        const d = value instanceof Date ? value : new Date(value);
        if (Number.isNaN(d.getTime())) return '-';
        return d.toLocaleString('pt-BR', {
          timeZone: 'America/Sao_Paulo',
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
      };
%>

<!-- Page header bar (Fluig-style) -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;gap:12px;flex-wrap:wrap">
  <div>
    <h2 style="margin:0;font-size:20px;font-weight:700;color:#202124">Processos</h2>
    <p style="margin:4px 0 0;font-size:13px;color:#5f6368">Catalogo de processos disponiveis para iniciar</p>
  </div>
  <a href="/processos/novo" class="wf-btn-primary"><i class="bi bi-plus-lg"></i> Novo processo</a>
</div>

<% if (onlyMine) { %>
  <div style="margin-bottom:16px;padding:10px 16px;border-radius:6px;background:#e8f0fe;color:#1a73e8;font-size:13px;font-weight:500;border:1px solid #c2d7f2">
    <i class="bi bi-funnel"></i> Exibindo somente processos criados por voce.
  </div>
<% } %>

<!-- Filter bar -->
<div class="wf-filter-bar">
  <form method="GET" action="<%= onlyMine ? '/processos/meus' : '/processos' %>" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;width:100%">
    <div style="flex:1;min-width:220px">
      <label>Pesquisar</label>
      <input name="search" value="<%= search %>" placeholder="Nome ou codigo do processo" />
    </div>
    <button class="wf-btn-primary" type="submit"><i class="bi bi-search"></i> Buscar</button>
  </form>
</div>

<!-- Process cards grid -->
<% if (!result.data.length) { %>
  <div class="wf-panel" style="text-align:center;padding:40px">
    <i class="bi bi-inbox" style="font-size:40px;color:#dadce0"></i>
    <p style="margin:12px 0 0;color:#5f6368;font-size:14px">Nenhum processo encontrado.</p>
  </div>
<% } else { %>
  <div class="wf-process-cards">
    <% result.data.forEach(function(item){ %>
      <div class="wf-process-card">
        <div class="wf-process-card-header">
          <div class="wf-process-card-icon">
            <i class="bi bi-diagram-3"></i>
          </div>
          <div class="wf-process-card-info">
            <h3><%= item.nome %></h3>
            <p><%= item.codigo %> &middot; v<%= item.versao || '0' %></p>
          </div>
        </div>

        <div class="wf-process-card-body">
          <% const steps = item.progress && item.progress.steps ? item.progress.steps : []; %>
          <% if (steps.length) { %>
            <div class="wf-step-line" style="margin-bottom:6px">
              <% steps.forEach(function(step){ %>
                <div class="wf-step-point <%= step.state === 'DONE' ? 'is-done' : (step.state === 'CURRENT' ? 'is-current' : '') %>" title="<%= step.name %>"></div>
              <% }) %>
            </div>
            <p style="font-size:11px;color:#5f6368;margin:0">
              <%= (item.progress && item.progress.summary_text) ? item.progress.summary_text : '' %>
            </p>
          <% } else { %>
            <p style="font-size:12px;color:#9aa0a6;margin:0">Sem execucao ativa</p>
          <% } %>

          <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap">
            <span class="wf-badge wf-badge-<%= item.status === 'ATIVO' ? 'green' : 'gray' %>"><%= item.status %></span>
            <% if (item.versao_status) { %>
              <span class="wf-badge wf-badge-blue"><%= item.versao_status %></span>
            <% } %>
          </div>
        </div>

        <div class="wf-process-card-footer">
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            <% if (item.can_execute) { %>
              <a href="/processos/<%= item.id %>/iniciar" class="wf-btn-primary" style="font-size:12px;padding:5px 12px"><i class="bi bi-play-fill"></i> Iniciar</a>
            <% } %>
            <a href="/processos/<%= item.id %>" class="wf-btn-secondary" style="font-size:12px;padding:5px 12px">Detalhes</a>
          </div>
          <div style="display:flex;gap:4px">
            <% if (item.can_edit) { %>
              <a href="/processos/<%= item.id %>/editar" title="Editar" style="color:#5f6368;font-size:16px"><i class="bi bi-pencil"></i></a>
            <% } %>
            <a href="/processos/<%= item.id %>/modelar" title="Modelador" style="color:#5f6368;font-size:16px"><i class="bi bi-bounding-box-circles"></i></a>
            <% if (item.can_admin) { %>
              <button type="button" class="delete-process-btn" data-process-id="<%= item.id %>" data-process-name="<%= item.nome %>" title="Excluir" style="color:#d93025;font-size:16px;background:none;border:none;cursor:pointer;padding:0"><i class="bi bi-trash"></i></button>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<div style="margin-top:16px;font-size:13px;color:#5f6368">
  Total: <strong><%= result.total %></strong> processo(s)
</div>

<%- include('../partials/shellEnd', { pageScript: '/workflow-assets/js/process-index.js' }) %>
