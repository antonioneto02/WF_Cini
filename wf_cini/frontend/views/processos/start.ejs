<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Processos', href: '/processos' }, { label: details.process.codigo, href: '/processos/' + details.process.id }, { label: 'Iniciar processo' }]
}) %>

<div class="grid lg:grid-cols-3 gap-4">
  <div class="wf-panel lg:col-span-2">
    <h3 class="font-semibold mb-3">Formulario inicial</h3>

    <div class="mb-3 max-w-sm">
      <label class="block text-sm font-semibold mb-1">Formulario</label>
      <select id="startFormSelect" class="w-full px-3 py-2 rounded-xl border border-slate-300">
        <option value="">Sem formulario</option>
        <% details.forms.forEach(function(form){ %>
          <option value="<%= form.id %>"><%= form.nome %></option>
        <% }) %>
      </select>
    </div>

    <form id="startProcessForm" data-process-id="<%= details.process.id %>" class="grid gap-3">
      <div id="startDynamicFormRoot" class="grid gap-3"></div>

      <div>
        <label class="block text-sm font-semibold mb-1">Payload complementar (JSON)</label>
        <textarea name="extraPayload" rows="5" class="w-full px-3 py-2 rounded-xl border border-slate-300 font-mono text-xs" placeholder='{"observacao":"inicio manual"}'></textarea>
      </div>

      <div class="flex justify-end">
        <button class="px-4 py-2 rounded-xl bg-ciniTeal text-white">Iniciar processo</button>
      </div>
    </form>
  </div>

  <div class="wf-panel">
    <h3 class="font-semibold mb-2">Dicas</h3>
    <ul class="text-sm text-slate-600 space-y-2">
      <li>- O processo precisa ter versao publicada.</li>
      <li>- Se houver formulario vinculado, os campos vao para o payload inicial.</li>
      <li>- A primeira UserTask do fluxo sera criada automaticamente.</li>
    </ul>
  </div>
</div>

<script id="startProcessSeed" type="application/json"><%- JSON.stringify({
  forms: details.forms,
}) %></script>

<%- include('../partials/shellEnd', {
  pageScript: '/workflow-assets/js/process-start.js',
}) %>
