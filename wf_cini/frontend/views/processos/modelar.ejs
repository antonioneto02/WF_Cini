<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Processos', href: '/processos' }, { label: payload.process.codigo, href: '/processos/' + payload.process.id }, { label: 'Modelador' }],
  extraStyles: [
    'https://unpkg.com/bpmn-js@17.11.1/dist/assets/diagram-js.css',
    'https://unpkg.com/bpmn-js@17.11.1/dist/assets/bpmn-js.css',
    'https://unpkg.com/bpmn-js@17.11.1/dist/assets/bpmn-font/css/bpmn.css'
  ]
}) %>

<div class="wf-panel" style="padding:0">
  <% if (readOnly) { %>
    <div style="padding:10px 16px;background:#fef7cd;border-bottom:1px solid #fde68a;font-size:.88rem;color:#92400e;border-radius:8px 8px 0 0">
      <i class="bi bi-info-circle"></i> Voce esta no modo de visualizacao. Este usuario nao pode editar/publicar alteracoes.
    </div>
  <% } %>

  <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid #e0e0e0">
    <div style="display:flex;gap:6px;flex-wrap:wrap">
      <button id="btnSaveVersion" class="wf-btn-primary" style="font-size:.85rem" <%= readOnly ? 'disabled' : '' %>><i class="bi bi-save"></i> Salvar nova versao</button>
      <button id="btnZoomIn" class="wf-btn-secondary" style="padding:6px 10px">Zoom +</button>
      <button id="btnZoomOut" class="wf-btn-secondary" style="padding:6px 10px">Zoom -</button>
      <button id="btnFit" class="wf-btn-secondary" style="padding:6px 10px">Fit</button>
      <button id="btnUndo" class="wf-btn-secondary" style="padding:6px 10px">Undo</button>
      <button id="btnRedo" class="wf-btn-secondary" style="padding:6px 10px">Redo</button>
      <button id="btnAlign" class="wf-btn-secondary" style="padding:6px 10px">Auto-align</button>
    </div>
    <div style="font-size:.85rem;color:#5f6368">
      Processo: <strong><%= payload.process.nome %></strong>
      <% if (payload.version) { %>
        | Versao: <strong>v<%= payload.version.versao %></strong>
      <% } %>
    </div>
  </div>

  <div class="wf-modeler-grid wf-modeler-grid-pro">
    <aside class="wf-toolbox-panel" id="wfToolboxPanel">
      <h3 class="font-semibold text-sm mb-2">Itens</h3>

      <p class="wf-toolbox-group-title">Activities</p>
      <div class="wf-toolbox-list mb-2">
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:UserTask"><i class="bi bi-person"></i><span>Tarefa de usuario</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:ServiceTask"><i class="bi bi-cpu"></i><span>Tarefa servico/API</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:SubProcess"><i class="bi bi-diagram-2"></i><span>Subprocesso</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:IntermediateCatchEvent"><i class="bi bi-hourglass-split"></i><span>Espera / temporizador</span></button>
      </div>

      <p class="wf-toolbox-group-title">Eventos</p>
      <div class="wf-toolbox-list mb-2">
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:StartEvent"><i class="bi bi-play-circle"></i><span>Inicio</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:EndEvent"><i class="bi bi-stop-circle"></i><span>Fim</span></button>
      </div>

      <p class="wf-toolbox-group-title">Gateways</p>
      <div class="wf-toolbox-list mb-2">
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:ExclusiveGateway"><i class="bi bi-sign-intersection"></i><span>Decisao</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:ParallelGateway"><i class="bi bi-distribute-vertical"></i><span>Paralelo</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:InclusiveGateway"><i class="bi bi-diagram-3"></i><span>Inclusivo</span></button>
      </div>

      <p class="wf-toolbox-group-title">Conectores</p>
      <div class="wf-toolbox-list mb-2">
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:SequenceFlow"><i class="bi bi-arrow-right"></i><span>Fluxo</span></button>
      </div>

      <p class="wf-toolbox-group-title">Enterprise</p>
      <div class="wf-toolbox-list">
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:ServiceTask" data-enterprise-kind="ECM"><i class="bi bi-folder2-open"></i><span>ECM</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:ServiceTask" data-enterprise-kind="DATABASE"><i class="bi bi-database"></i><span>Banco de dados</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:UserTask" data-enterprise-kind="MANAGER"><i class="bi bi-person-badge"></i><span>Aprovacao gestor</span></button>
        <button type="button" class="wf-toolbox-item" data-tool-type="bpmn:ServiceTask" data-enterprise-kind="AUTOMATION"><i class="bi bi-robot"></i><span>Automacao externa</span></button>
      </div>
    </aside>

    <div class="wf-modeler-canvas-wrap">
      <div id="bpmnCanvas" class="wf-modeler-canvas"></div>
      <div id="flowInsertFab" class="wf-flow-insert-fab" style="display:none;">+</div>
    </div>

    <aside class="wf-props-panel">
      <h3 style="font-size:.95rem;font-weight:600;margin:0 0 14px;color:#202124">Propriedades do elemento</h3>
      <form id="propsForm" style="display:grid;gap:12px">
        <input type="hidden" id="selectedElementId" />

        <div>
          <label class="wf-form-label">Nome da atividade</label>
          <input id="propName" class="wf-form-input" />
        </div>

        <div>
          <label class="wf-form-label">Execucao da tarefa</label>
          <select id="propTaskType" class="wf-form-input">
            <option value="USER">Usuario</option>
            <option value="SERVICE">Servico</option>
            <option value="SCRIPT">Script</option>
            <option value="ECM">ECM</option>
            <option value="DB">Banco de Dados</option>
            <option value="AUTOMATION">Automacao Externa</option>
            <option value="MANAGER">Aprovacao de Gestor</option>
          </select>
        </div>

        <div id="apiParamsSection" style="padding:12px;border:1px solid #e0e0e0;border-radius:6px;background:#fafafa;display:none">
          <label class="wf-form-label">Endpoint gerado para iniciar via API</label>
          <input id="propApiEndpointPreview" class="wf-form-input" readonly style="font-family:monospace;font-size:.8rem;background:#f3f4f6" />
          <label class="wf-form-label">Quantidade de parametros da API</label>
          <input id="propApiParamCount" type="number" min="0" max="30" class="wf-form-input" placeholder="Ex: 3" />
          <p style="font-size:.78rem;color:#5f6368;margin:6px 0 0">Informe quantos parametros a API de inicio do processo deve receber para esta tarefa de servico.</p>
          <div id="propApiParamsContainer" style="margin-top:8px;display:grid;gap:8px"></div>
        </div>

        <div id="automationExternalSection" style="padding:12px;border:1px solid #e0e0e0;border-radius:6px;background:#fafafa;display:none">
          <label class="wf-form-label">Endpoint da automacao externa</label>
          <input id="propAutomationEndpoint" class="wf-form-input" placeholder="https://api.exemplo.com/automacao" />

          <label class="wf-form-label" style="margin-top:10px">Metodo HTTP</label>
          <select id="propAutomationMethod" class="wf-form-input">
            <option value="POST">POST</option>
            <option value="PUT">PUT</option>
            <option value="PATCH">PATCH</option>
          </select>

          <label class="wf-form-label" style="margin-top:10px">Campos da resposta do formulario para enviar</label>
          <textarea id="propAutomationPayloadMap" rows="3" class="wf-form-input" style="resize:vertical" placeholder="Ex: cliente.nome, cliente.cpf:documento"></textarea>
          <p style="font-size:.78rem;color:#5f6368;margin:6px 0 0">Use virgula, ponto e virgula ou quebra de linha. Formato opcional origem:destino para renomear no payload enviado.</p>

          <label class="wf-form-label" style="margin-top:10px">Automacao cadastrada (opcional)</label>
          <select id="propAutomationId" class="wf-form-input">
            <option value="">Nenhuma</option>
            <% (payload.automations || []).forEach(function(item){ %>
              <option value="<%= item.id %>"><%= item.nome %> - <%= item.endpoint_url %></option>
            <% }) %>
          </select>
          <p style="font-size:.78rem;color:#5f6368;margin:6px 0 0">Quando endpoint da automacao externa estiver preenchido, ele tem prioridade sobre esta lista.</p>
        </div>

        <div>
          <label class="wf-form-label">Responsavel</label>
          <div style="position:relative">
            <input id="propResponsible" placeholder="Digite o nome do usuario" class="wf-form-input" autocomplete="off" />
            <input type="hidden" id="propResponsibleId" />
            <div id="responsibleUsersList" style="display:none;position:absolute;left:0;right:0;z-index:20;margin-top:4px;max-height:220px;overflow:auto;border:1px solid #dadce0;border-radius:6px;background:#fff;box-shadow:0 4px 12px rgba(0,0,0,.1)"></div>
          </div>
        </div>

        <div>
          <label class="wf-form-label">SLA (horas)</label>
          <input id="propSla" type="number" min="1" class="wf-form-input" />
        </div>

        <div>
          <label class="wf-form-label">Condicao (gateway/fluxo)</label>
          <textarea id="propCondition" rows="2" class="wf-form-input" style="resize:vertical" placeholder="Ex: payload.valor > 5000"></textarea>
        </div>

        <div>
          <label class="wf-form-label">Formulario vinculado</label>
          <select id="propFormId" class="wf-form-input">
            <option value="">Nenhum</option>
            <% payload.forms.forEach(function(form){ %>
              <option value="<%= form.id %>"><%= form.nome %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="wf-form-label">Consulta SQL / comando DB</label>
          <textarea id="propDbQuery" rows="2" class="wf-form-input" style="resize:vertical" placeholder="SELECT ... / EXEC ..."></textarea>
        </div>

        <div>
          <label class="wf-form-label">Politica ECM</label>
          <select id="propEcmPolicy" class="wf-form-input">
            <option value="OWNER_ONLY">Somente dono</option>
            <option value="PROCESS_VIEWERS">Visualizadores do processo</option>
            <option value="PROCESS_EDITORS">Editores do processo</option>
          </select>
        </div>

        <div>
          <label class="wf-form-label">Gestores aprovadores</label>
          <div id="propManagerUsersSelected" style="display:flex;flex-wrap:wrap;gap:6px;padding:6px 0;min-height:30px"></div>
          <div style="position:relative">
            <input id="propManagerUsersInput" placeholder="Digite o nome do gestor" class="wf-form-input" autocomplete="off" />
            <div id="managerUsersList" style="display:none;position:absolute;left:0;right:0;z-index:20;margin-top:4px;max-height:220px;overflow:auto;border:1px solid #dadce0;border-radius:6px;background:#fff;box-shadow:0 4px 12px rgba(0,0,0,.1)"></div>
          </div>
          <textarea id="propManagerUsers" style="display:none"></textarea>
        </div>

        <p style="font-size:.78rem;color:#5f6368">
          Dica: selecione dois elementos e clique em "Fluxo (seta)" para conectar manualmente.
        </p>

        <button type="button" id="btnApplyProps" class="wf-btn-primary" style="width:100%" <%= readOnly ? 'disabled' : '' %>><i class="bi bi-check-lg"></i> APLICAR ALTERACOES</button>
      </form>
    </aside>
  </div>
</div>

<div id="modelerContextMenu" class="wf-context-menu" style="display:none;">
  <button type="button" data-action="edit">Editar</button>
  <button type="button" data-action="delete">Excluir</button>
  <button type="button" data-action="duplicate">Duplicar</button>
  <button type="button" data-action="add-task-after">Adicionar tarefa depois</button>
  <button type="button" data-action="add-gateway-after">Adicionar gateway</button>
  <button type="button" data-action="associate-form">Associar formulario</button>
  <button type="button" data-action="set-responsible">Definir responsavel</button>
</div>

<script id="modelerSeed" type="application/json"><%- JSON.stringify({
  processoId: payload.process.id,
  processCode: payload.process.codigo,
  bpmnXml: bpmnXml,
  propriedades: propriedades,
  forms: payload.forms,
  automations: payload.automations || [],
  readOnly: Boolean(readOnly)
}) %></script>
<script type="module" src="/workflow-assets/js/modeler.js"></script>

<%- include('../partials/shellEnd', { pageScript: '' }) %>
