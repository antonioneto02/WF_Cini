<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Processos', href: '/processos' }, { label: 'Novo' }]
}) %>

<!-- Page header -->
<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
  <a href="/processos" class="wf-btn-secondary" style="padding:6px 10px" title="Voltar"><i class="bi bi-arrow-left"></i></a>
  <div>
    <h2 style="margin:0;font-size:1.15rem;font-weight:600;color:#202124">Novo processo</h2>
    <p style="margin:2px 0 0;font-size:.85rem;color:#5f6368">Passo 1: dados basicos. Passo 2: modelador BPMN.</p>
  </div>
</div>

<div class="wf-panel" style="width:100%">
  <form id="processCreateForm" style="display:grid;gap:16px">
    <div>
      <label class="wf-form-label">Nome do processo</label>
      <input required name="nome" class="wf-form-input" placeholder="Ex: Aprovacao de Pagamento" />
    </div>

    <div>
      <label class="wf-form-label">Descricao</label>
      <textarea name="descricao" rows="4" class="wf-form-input" placeholder="Objetivo e escopo do processo" style="resize:vertical"></textarea>
    </div>

    <fieldset style="border:1px solid #e0e0e0;border-radius:8px;padding:16px">
      <legend style="font-size:.9rem;font-weight:600;color:#202124;padding:0 6px">Permissoes por usuario</legend>
      <p style="font-size:.8rem;color:#5f6368;margin:0 0 12px">Digite o nome e selecione o usuario na lista, igual ao seletor de responsavel do modelador.</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div>
          <label class="wf-form-label">Apenas visualizar</label>
          <div class="wf-perm-picker">
            <textarea name="viewers" class="wf-perm-storage" style="display:none"></textarea>
            <div class="wf-perm-box" data-role="tags"></div>
            <input type="text" class="wf-form-input wf-perm-input" data-role="input" placeholder="Digite nome" autocomplete="off" />
            <div class="wf-perm-suggestions hidden" data-role="suggestions"></div>
          </div>
        </div>
        <div>
          <label class="wf-form-label">Editar processo</label>
          <div class="wf-perm-picker">
            <textarea name="editors" class="wf-perm-storage" style="display:none"></textarea>
            <div class="wf-perm-box" data-role="tags"></div>
            <input type="text" class="wf-form-input wf-perm-input" data-role="input" placeholder="Digite nome" autocomplete="off" />
            <div class="wf-perm-suggestions hidden" data-role="suggestions"></div>
          </div>
        </div>
        <div>
          <label class="wf-form-label">Modelar fluxo</label>
          <div class="wf-perm-picker">
            <textarea name="modelers" class="wf-perm-storage" style="display:none"></textarea>
            <div class="wf-perm-box" data-role="tags"></div>
            <input type="text" class="wf-form-input wf-perm-input" data-role="input" placeholder="Digite nome" autocomplete="off" />
            <div class="wf-perm-suggestions hidden" data-role="suggestions"></div>
          </div>
        </div>
        <div>
          <label class="wf-form-label">Executar tarefas/iniciar</label>
          <div class="wf-perm-picker">
            <textarea name="executors" class="wf-perm-storage" style="display:none"></textarea>
            <div class="wf-perm-box" data-role="tags"></div>
            <input type="text" class="wf-form-input wf-perm-input" data-role="input" placeholder="Digite nome" autocomplete="off" />
            <div class="wf-perm-suggestions hidden" data-role="suggestions"></div>
          </div>
        </div>
      </div>
    </fieldset>

    <fieldset style="border:1px solid #e0e0e0;border-radius:8px;padding:16px">
      <legend style="font-size:.9rem;font-weight:600;color:#202124;padding:0 6px">Integracoes e APIs</legend>
      <div style="display:flex;gap:20px;flex-wrap:wrap;font-size:.88rem">
        <label style="display:flex;align-items:center;gap:6px"><input type="checkbox" name="allow_protheus" checked /> Permitir inicio por Protheus</label>
        <label style="display:flex;align-items:center;gap:6px"><input type="checkbox" name="allow_mysql" checked /> Permitir inicio por MySQL</label>
        <label style="display:flex;align-items:center;gap:6px"><input type="checkbox" name="allow_external" checked /> Permitir API externa</label>
      </div>
    </fieldset>

    <div style="display:flex;gap:8px;justify-content:flex-end;padding-top:12px;border-top:1px solid #e0e0e0">
      <a href="/processos" class="wf-btn-secondary">Cancelar</a>
      <button type="submit" class="wf-btn-primary"><i class="bi bi-check-lg"></i> Salvar processo</button>
    </div>
  </form>
</div>

<script src="/workflow-assets/js/process-permissions-picker.js"></script>

<%- include('../partials/shellEnd', { pageScript: '/workflow-assets/js/process-new.js' }) %>
