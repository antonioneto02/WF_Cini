<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Processos', href: '/processos' }, { label: 'Novo' }]
}) %>

<div class="wf-panel max-w-2xl">
  <div class="mb-4 rounded-xl border border-cyan-200 bg-cyan-50 p-3 text-sm text-cyan-900">
    <p class="font-semibold">Fluxo de criacao</p>
    <p>Passo 1: dados basicos do processo.</p>
    <p>Passo 2: abrir modelador BPMN automaticamente.</p>
  </div>

  <form id="processCreateForm" class="grid gap-4">
    <div>
      <label class="block text-sm font-semibold mb-1">Nome do processo</label>
      <input required name="nome" class="w-full px-3 py-2 rounded-xl border border-slate-300" placeholder="Ex: Aprovacao de Pagamento" />
    </div>

    <div>
      <label class="block text-sm font-semibold mb-1">Descricao</label>
      <textarea name="descricao" rows="4" class="w-full px-3 py-2 rounded-xl border border-slate-300" placeholder="Objetivo e escopo do processo"></textarea>
    </div>

    <div class="flex gap-2 justify-end">
      <a href="/processos" class="px-4 py-2 rounded-xl border border-slate-300">Cancelar</a>
      <button class="px-4 py-2 rounded-xl bg-ciniBlue text-white">Salvar processo</button>
    </div>
  </form>
</div>

<%- include('../partials/shellEnd', { pageScript: '/workflow-assets/js/process-new.js' }) %>
