<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | Workflow CINI</title>
  <link rel="icon" type="image/png" href="/css/logo-cini.png">
  <link rel="shortcut icon" type="image/png" href="/css/logo-cini.png">
  <link rel="apple-touch-icon" href="/css/logo-cini.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            ciniBlue: '#1a73e8',
            ciniTeal: '#1a73e8',
            ciniSky: '#e8f0fe',
            ciniInk: '#202124',
            ciniSoft: '#f5f5f5',
          },
          fontFamily: {
            display: ['Roboto', 'sans-serif'],
            body: ['Roboto', 'sans-serif'],
          },
        },
      },
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <% ((typeof extraStyles !== 'undefined' && Array.isArray(extraStyles)) ? extraStyles : []).forEach(function(href){ %>
    <link rel="stylesheet" href="<%= href %>">
  <% }) %>
  <link rel="stylesheet" href="/workflow-assets/css/workflow.css">
</head>
<body class="wf-body font-body text-ciniInk">
  <div class="wf-bg-layer"></div>
  <div class="wf-app wf-sidebar-collapsed">
    <aside class="wf-sidebar">
      <div class="wf-brand">
        <img src="/css/logo-cini.png" alt="CINI" class="wf-brand-logo">
        <div>
          <p class="wf-brand-title">CINI Workflow</p>
          <p class="wf-brand-subtitle">Plataforma BPM</p>
        </div>
      </div>

      <nav class="wf-nav">
        <a href="/processos" class="wf-nav-item <%= currentPath && currentPath.startsWith('/processos') && !currentPath.startsWith('/processos/meus') ? 'active' : '' %>">
          <i class="bi bi-diagram-3"></i><span>Processos</span>
        </a>
        <a href="/processos/meus" class="wf-nav-item <%= currentPath && currentPath.startsWith('/processos/meus') ? 'active' : '' %>">
          <i class="bi bi-person-workspace"></i><span>Meus processos</span>
        </a>
        <a href="/tarefas" class="wf-nav-item <%= currentPath && currentPath.startsWith('/tarefas') ? 'active' : '' %>">
          <i class="bi bi-check2-square"></i><span>Central de tarefas</span>
        </a>
        <a href="/solicitacoes" class="wf-nav-item <%= currentPath && currentPath.startsWith('/solicitacoes') ? 'active' : '' %>">
          <i class="bi bi-file-earmark-text"></i><span>Solicitacoes</span>
        </a>
        <a href="/formularios/construtor" class="wf-nav-item <%= currentPath && currentPath.startsWith('/formularios') ? 'active' : '' %>">
          <i class="bi bi-ui-checks-grid"></i><span>Formularios</span>
        </a>
        <a href="/automacoes" class="wf-nav-item <%= currentPath && currentPath.startsWith('/automacoes') ? 'active' : '' %>">
          <i class="bi bi-robot"></i><span>Automacoes</span>
        </a>
        <a href="/apis/processos" class="wf-nav-item <%= currentPath && currentPath.startsWith('/apis/processos') ? 'active' : '' %>">
          <i class="bi bi-plug"></i><span>APIs dos Processos</span>
        </a>
        <a href="/admin/limpeza-total" class="wf-nav-item <%= currentPath && currentPath.startsWith('/admin/limpeza-total') ? 'active' : '' %>">
          <i class="bi bi-trash3"></i><span>Limpeza Total</span>
        </a>
        <% if (user && user.isDev) { %>
          <a href="/bpm/dev/apis" class="wf-nav-item <%= currentPath && currentPath.startsWith('/bpm/dev/apis') ? 'active' : '' %>">
            <i class="bi bi-code-square"></i><span>Modo Dev APIs</span>
          </a>
        <% } %>
      </nav>

      <div class="wf-sidebar-footer">
        <p class="text-xs">Logado como</p>
        <p class="font-semibold"><%= (user && user.nome) || 'Usuario' %></p>
      </div>
    </aside>

    <main class="wf-main">
      <header class="wf-topbar">
        <div class="wf-heading-group">
          <div>
            <div class="wf-breadcrumb">
              <a href="/processos">Inicio</a>
              <% (breadcrumbs || []).forEach(function(item){ %>
                <span>&rsaquo;</span>
                <% if (item.href) { %>
                  <a href="<%= item.href %>"><%= item.label %></a>
                <% } else { %>
                  <strong><%= item.label %></strong>
                <% } %>
              <% }); %>
            </div>
          </div>
        </div>
        <div class="wf-user-area">
          <div class="wf-notif-wrap">
            <button type="button" id="wfNotifToggle" class="wf-notif-toggle" aria-haspopup="true" aria-expanded="false" title="Notificacoes">
              <i class="bi bi-bell"></i>
              <span id="wfNotifBadge" class="wf-notif-badge" style="display:none">0</span>
            </button>
            <div id="wfNotifDropdown" class="wf-notif-dropdown" style="display:none;">
              <div class="wf-notif-header">
                <strong>Notificacoes</strong>
                <button type="button" id="wfNotifMarkAllBtn" class="wf-notif-link">Marcar todas</button>
              </div>
              <div id="wfNotifList" class="wf-notif-list">
                <p class="wf-notif-empty">Carregando...</p>
              </div>
            </div>
          </div>
          <div class="wf-user-chip" id="wfUserToggle" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false">
            <i class="bi bi-person-circle"></i>
            <span><%= (user && user.nome) || 'Usuario' %></span>
          </div>
          <div class="wf-user-dropdown" id="wfUserDropdown" style="display:none;">
            <div class="wf-user-dropdown-header">
              <strong><%= (user && user.nome) || 'Usuario' %></strong>
            </div>
            <div class="wf-user-dropdown-actions">
              <a href="/logout" class="wf-logout-link"><i class="bi bi-box-arrow-right"></i> Sair</a>
            </div>
          </div>
        </div>
      </header>

      <section class="wf-content">
