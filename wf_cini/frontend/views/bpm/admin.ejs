<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Administracao BPM' }]
}) %>

<div class="grid md:grid-cols-4 gap-4">
  <article class="wf-panel">
    <p class="text-sm text-slate-500">Processos</p>
    <p class="text-3xl font-bold"><%= stats.processos %></p>
  </article>
  <article class="wf-panel">
    <p class="text-sm text-slate-500">Tarefas</p>
    <p class="text-3xl font-bold"><%= stats.tarefas %></p>
  </article>
  <article class="wf-panel">
    <p class="text-sm text-slate-500">Solicitacoes</p>
    <p class="text-3xl font-bold"><%= stats.solicitacoes %></p>
  </article>
  <article class="wf-panel">
    <p class="text-sm text-slate-500">Formularios</p>
    <p class="text-3xl font-bold"><%= stats.formularios %></p>
  </article>
</div>

<div class="wf-panel mt-4">
  <h3 class="font-semibold mb-2">Acoes rapidas</h3>
  <div class="flex gap-2 flex-wrap">
    <a href="/processos/novo" class="px-3 py-2 rounded-xl border border-slate-300">Novo processo</a>
    <a href="/formularios/construtor" class="px-3 py-2 rounded-xl border border-slate-300">Novo formulario</a>
    <a href="/processos" class="px-3 py-2 rounded-xl border border-slate-300">Abrir modelador</a>
  </div>
</div>

<%- include('../partials/shellEnd', { pageScript: '' }) %>
