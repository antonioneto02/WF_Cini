<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Painel de controle' }]
}) %>

<%
  const widgetSet = new Set((personalization && personalization.widgets) || []);
  const showWidget = (name) => widgetSet.has(name);
  const atalhos = (personalization && personalization.atalhos) || [];
%>

<div class="wf-dash-welcome">
  <div>
    <h2>Painel de controle Fluig-like</h2>
    <p>
      Perfil atual: <strong><%= personalization && personalization.perfil ? personalization.perfil : 'OPERACAO' %></strong>
      &middot; Widgets personalizaveis por usuario
    </p>
  </div>
  <div class="wf-dash-welcome-actions">
    <button id="wfCustomizeDashboardBtn" type="button" class="wf-btn-secondary"><i class="bi bi-sliders"></i> Personalizar painel</button>
    <a href="/processos/novo" class="wf-btn-primary"><i class="bi bi-plus-lg"></i> Novo processo</a>
    <a href="/tarefas" class="wf-btn-secondary"><i class="bi bi-check2-square"></i> Central de tarefas</a>
  </div>
</div>

<% if (atalhos.length) { %>
  <div class="wf-panel" style="margin-bottom:16px">
    <div class="wf-dash-card-header" style="padding:0 0 12px;border-bottom:none">
      <h3><i class="bi bi-lightning"></i> Atalhos do perfil</h3>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <% atalhos.forEach(function(item){ %>
        <a href="<%= item.href %>" class="wf-btn-secondary" style="font-size:.82rem;padding:6px 12px">
          <i class="bi <%= item.icon || 'bi-link-45deg' %>"></i> <%= item.label %>
        </a>
      <% }) %>
    </div>
  </div>
<% } %>

<% if (showWidget('kpis')) { %>
  <div class="wf-kpi-row">
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#e8f0fe;color:#1a73e8"><i class="bi bi-diagram-3"></i></div><div><span class="wf-kpi-value"><%= stats.processos %></span><span class="wf-kpi-label">Processos</span></div></div>
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#fef7cd;color:#e8a817"><i class="bi bi-hourglass-split"></i></div><div><span class="wf-kpi-value"><%= stats.tarefasPendentes %></span><span class="wf-kpi-label">Tarefas pendentes</span></div></div>
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#e8f0fe;color:#1a73e8"><i class="bi bi-arrow-repeat"></i></div><div><span class="wf-kpi-value"><%= stats.tarefasAndamento %></span><span class="wf-kpi-label">Em andamento</span></div></div>
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#e6f4ea;color:#1e8e3e"><i class="bi bi-check-circle"></i></div><div><span class="wf-kpi-value"><%= stats.tarefasConcluidas %></span><span class="wf-kpi-label">Concluidas</span></div></div>
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#e8f0fe;color:#1a73e8"><i class="bi bi-file-earmark-text"></i></div><div><span class="wf-kpi-value"><%= stats.solicitacoesAbertas %></span><span class="wf-kpi-label">Solic. abertas</span></div></div>
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#e6f4ea;color:#1e8e3e"><i class="bi bi-file-earmark-check"></i></div><div><span class="wf-kpi-value"><%= stats.solicitacoesConcluidas %></span><span class="wf-kpi-label">Solic. concluidas</span></div></div>
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#fce8e6;color:#d93025"><i class="bi bi-lightning-charge"></i></div><div><span class="wf-kpi-value"><%= stats.automacoesAtivas %></span><span class="wf-kpi-label">Automacoes</span></div></div>
    <div class="wf-kpi-card"><div class="wf-kpi-icon" style="background:#f3e8fd;color:#8430ce"><i class="bi bi-ui-checks-grid"></i></div><div><span class="wf-kpi-value"><%= stats.formularios %></span><span class="wf-kpi-label">Formularios</span></div></div>
  </div>
<% } %>

<div class="wf-dash-grid">
  <% if (showWidget('tarefas')) { %>
    <div class="wf-panel wf-dash-card">
      <div class="wf-dash-card-header"><h3><i class="bi bi-check2-square"></i> Minhas tarefas</h3><a href="/tarefas" class="wf-dash-link">Ver todas <i class="bi bi-chevron-right"></i></a></div>
      <% if (!highlights.tarefas.length) { %><div class="wf-dash-empty"><i class="bi bi-inbox"></i><p>Nenhuma tarefa na sua fila.</p></div><% } else { %>
        <table class="wf-table" style="margin:0"><thead><tr><th>Atividade</th><th>Processo</th><th>Status</th></tr></thead><tbody>
          <% highlights.tarefas.forEach(function(item){ %>
            <tr onclick="window.location='/tarefas/<%= item.id %>'" style="cursor:pointer">
              <td style="font-weight:500"><%= item.nome_etapa %></td><td style="color:#5f6368;font-size:.85rem"><%= item.processo_nome %></td>
              <td><span class="<%= item.status === 'CONCLUIDA' ? 'wf-badge-green' : item.status === 'EM_ANDAMENTO' ? 'wf-badge-blue' : 'wf-badge-yellow' %>"><%= item.status === 'CONCLUIDA' ? 'Concluida' : item.status === 'EM_ANDAMENTO' ? 'Em andamento' : 'Pendente' %></span></td>
            </tr>
          <% }) %>
        </tbody></table>
      <% } %>
    </div>
  <% } %>

  <% if (showWidget('solicitacoes')) { %>
    <div class="wf-panel wf-dash-card">
      <div class="wf-dash-card-header"><h3><i class="bi bi-file-earmark-text"></i> Solicitacoes recentes</h3><a href="/solicitacoes" class="wf-dash-link">Ver todas <i class="bi bi-chevron-right"></i></a></div>
      <% if (!highlights.solicitacoes.length) { %><div class="wf-dash-empty"><i class="bi bi-inbox"></i><p>Sem solicitacoes recentes.</p></div><% } else { %>
        <table class="wf-table" style="margin:0"><thead><tr><th>#</th><th>Processo</th><th>Solicitante</th><th>Status</th></tr></thead><tbody>
          <% highlights.solicitacoes.forEach(function(item){ %>
            <tr onclick="window.location='/solicitacoes/<%= item.id %>'" style="cursor:pointer">
              <td style="font-weight:600;color:var(--wf-primary)">#<%= item.id %></td><td><%= item.processo_nome %></td><td style="color:#5f6368;font-size:.85rem"><%= item.solicitante || '-' %></td>
              <td><span class="<%= item.status === 'CONCLUIDA' ? 'wf-badge-green' : 'wf-badge-blue' %>"><%= item.status === 'CONCLUIDA' ? 'Concluida' : 'Em andamento' %></span></td>
            </tr>
          <% }) %>
        </tbody></table>
      <% } %>
    </div>
  <% } %>

  <% if (showWidget('processos')) { %>
    <div class="wf-panel wf-dash-card">
      <div class="wf-dash-card-header"><h3><i class="bi bi-diagram-3"></i> Processos</h3><a href="/processos" class="wf-dash-link">Ver todos <i class="bi bi-chevron-right"></i></a></div>
      <% if (!highlights.processos.length) { %><div class="wf-dash-empty"><i class="bi bi-inbox"></i><p>Sem processos para mostrar.</p></div><% } else { %>
        <table class="wf-table" style="margin:0"><thead><tr><th>Nome</th><th>Codigo</th><th>Status</th></tr></thead><tbody>
          <% highlights.processos.forEach(function(item){ %>
            <tr onclick="window.location='/processos/<%= item.id %>'" style="cursor:pointer"><td style="font-weight:500"><%= item.nome %></td><td style="color:#5f6368;font-size:.85rem"><%= item.codigo %></td><td><span class="<%= item.status === 'ATIVO' ? 'wf-badge-green' : 'wf-badge-gray' %>"><%= item.status %></span></td></tr>
          <% }) %>
        </tbody></table>
      <% } %>
    </div>
  <% } %>

  <% if (showWidget('automacoes')) { %>
    <div class="wf-panel wf-dash-card">
      <div class="wf-dash-card-header"><h3><i class="bi bi-lightning-charge"></i> Automacoes</h3><a href="/automacoes" class="wf-dash-link">Catalogo <i class="bi bi-chevron-right"></i></a></div>
      <% if (!highlights.automacoes.length) { %><div class="wf-dash-empty"><i class="bi bi-inbox"></i><p>Nenhuma automacao cadastrada.</p></div><% } else { %>
        <table class="wf-table" style="margin:0"><thead><tr><th>Nome</th><th>Endpoint</th><th>Status</th></tr></thead><tbody>
          <% highlights.automacoes.forEach(function(item){ %>
            <tr><td style="font-weight:500"><%= item.nome %></td><td style="color:#5f6368;font-size:.85rem"><%= item.metodo_http %> <%= item.endpoint_url %></td><td><span class="<%= item.ativo ? 'wf-badge-green' : 'wf-badge-red' %>"><%= item.ativo ? 'Ativa' : 'Inativa' %></span></td></tr>
          <% }) %>
        </tbody></table>
      <% } %>
    </div>
  <% } %>

  <% if (showWidget('sla')) { %>
    <div class="wf-panel wf-dash-card">
      <div class="wf-dash-card-header"><h3><i class="bi bi-alarm"></i> Alertas SLA / Escalonamento</h3></div>
      <% if (!slaAlerts || !slaAlerts.length) { %>
        <div class="wf-dash-empty"><i class="bi bi-shield-check"></i><p>Sem alertas de SLA no momento.</p></div>
      <% } else { %>
        <table class="wf-table" style="margin:0"><thead><tr><th>Titulo</th><th>Prioridade</th><th>Status</th></tr></thead><tbody>
          <% slaAlerts.forEach(function(item){ %>
            <tr><td><%= item.titulo %><br><span style="font-size:.78rem;color:#5f6368"><%= item.mensagem || '-' %></span></td><td><span class="<%= Number(item.prioridade) >= 4 ? 'wf-badge-red' : 'wf-badge-yellow' %>">P<%= item.prioridade %></span></td><td><span class="<%= item.status === 'UNREAD' ? 'wf-badge-blue' : 'wf-badge-gray' %>"><%= item.status === 'UNREAD' ? 'Nao lida' : 'Lida' %></span></td></tr>
          <% }) %>
        </tbody></table>
      <% } %>
    </div>
  <% } %>

  <% if (showWidget('notificacoes')) { %>
    <div class="wf-panel wf-dash-card">
      <div class="wf-dash-card-header"><h3><i class="bi bi-bell"></i> Notificacoes (<span id="wfDashboardNotifUnread"><%= notificationUnread || 0 %></span> nao lidas)</h3></div>
      <% if (!notifications || !notifications.length) { %>
        <div class="wf-dash-empty"><i class="bi bi-bell-slash"></i><p>Nenhuma notificacao.</p></div>
      <% } else { %>
        <table class="wf-table" style="margin:0"><thead><tr><th>Titulo</th><th>Tipo</th><th>Status</th><th>Acoes</th></tr></thead><tbody>
          <% notifications.forEach(function(item){ %>
            <tr data-notif-id="<%= item.id %>">
              <td><%= item.titulo %><br><span style="font-size:.78rem;color:#5f6368"><%= item.mensagem || '-' %></span></td>
              <td><span class="wf-badge-gray"><%= item.tipo %></span></td>
              <td data-role="notif-status"><span class="<%= item.status === 'UNREAD' ? 'wf-badge-blue' : 'wf-badge-green' %>"><%= item.status === 'UNREAD' ? 'Nao lida' : 'Lida' %></span></td>
              <td>
                <% if (item.status === 'UNREAD') { %>
                  <button type="button" class="wf-notif-action-read wf-dashboard-notif-read" data-id="<%= item.id %>">Marcar lida</button>
                <% } else { %>
                  <span style="font-size:.75rem;color:#80868b">-</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody></table>
      <% } %>
    </div>
  <% } %>

  <% if (showWidget('colaboracao')) { %>
    <div class="wf-panel wf-dash-card">
      <div class="wf-dash-card-header"><h3><i class="bi bi-chat-dots"></i> Trilha colaborativa</h3></div>
      <% if (!collaborationFeed || !collaborationFeed.length) { %>
        <div class="wf-dash-empty"><i class="bi bi-chat-square-text"></i><p>Sem comentarios recentes no seu contexto.</p></div>
      <% } else { %>
        <div style="padding:10px 16px;display:grid;gap:10px;max-height:320px;overflow:auto">
          <% collaborationFeed.forEach(function(item){ %>
            <div style="border:1px solid #e0e0e0;border-radius:6px;padding:10px;background:#fafafa">
              <p style="margin:0 0 4px;font-size:.8rem;color:#5f6368"><strong><%= item.autor %></strong> &middot; <%= item.processo_nome || '-' %> &middot; #<%= item.instancia_processo_id %></p>
              <p style="margin:0;font-size:.86rem;color:#202124"><%= item.mensagem %></p>
              <p style="margin:4px 0 0;font-size:.75rem;color:#80868b"><%= item.tarefa_id ? ('Tarefa #' + item.tarefa_id) : 'Comentario na solicitacao' %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% } %>
</div>

<div id="wfDashboardPrefsModal" class="wf-modal-overlay" style="display:none">
  <div class="wf-modal-card">
    <h3 style="margin:0 0 10px;font-size:1rem;color:#202124">Personalizar painel</h3>
    <p style="margin:0 0 12px;font-size:.82rem;color:#5f6368">Marque quais widgets deseja exibir no seu dashboard.</p>
    <form id="wfDashboardPrefsForm" style="display:grid;gap:8px">
      <label><input type="checkbox" name="widgets" value="kpis"> KPIs</label>
      <label><input type="checkbox" name="widgets" value="tarefas"> Minhas tarefas</label>
      <label><input type="checkbox" name="widgets" value="solicitacoes"> Solicitacoes</label>
      <label><input type="checkbox" name="widgets" value="processos"> Processos</label>
      <label><input type="checkbox" name="widgets" value="automacoes"> Automacoes</label>
      <label><input type="checkbox" name="widgets" value="sla"> Alertas SLA</label>
      <label><input type="checkbox" name="widgets" value="notificacoes"> Notificacoes</label>
      <label><input type="checkbox" name="widgets" value="colaboracao"> Trilha colaborativa</label>
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:10px">
        <button type="button" id="wfCancelPrefsBtn" class="wf-btn-secondary">Cancelar</button>
        <button type="submit" class="wf-btn-primary">Salvar preferencias</button>
      </div>
    </form>
  </div>
</div>

<script id="dashboardPersonalizationSeed" type="application/json"><%- JSON.stringify({
  personalization: personalization || null,
}) %></script>

<style>
  .wf-dash-welcome { display:flex; justify-content:space-between; align-items:center; gap:16px; padding:20px 24px; border-radius:8px; background:linear-gradient(135deg,#1a73e8 0%,#4285f4 100%); color:#fff; margin-bottom:20px; }
  .wf-dash-welcome h2 { font-size:1.2rem; font-weight:600; margin:0 0 4px; }
  .wf-dash-welcome p { font-size:.88rem; margin:0; opacity:.92; }
  .wf-dash-welcome-actions { display:flex; gap:8px; flex-wrap:wrap; }
  .wf-dash-welcome-actions .wf-btn-primary { background:#fff; color:#1a73e8; border:none; }
  .wf-dash-welcome-actions .wf-btn-primary:hover { background:#e8f0fe; }
  .wf-dash-welcome-actions .wf-btn-secondary { color:#fff; border-color:rgba(255,255,255,.5); }
  .wf-dash-welcome-actions .wf-btn-secondary:hover { background:rgba(255,255,255,.12); }
  .wf-dash-grid { display:grid; grid-template-columns:repeat(2, 1fr); gap:16px; }
  .wf-dash-card { padding:0 !important; overflow:hidden; }
  .wf-dash-card-header { display:flex; justify-content:space-between; align-items:center; padding:14px 18px; border-bottom:1px solid #e0e0e0; }
  .wf-dash-card-header h3 { font-size:.95rem; font-weight:600; color:#202124; margin:0; display:flex; align-items:center; gap:6px; }
  .wf-dash-link { font-size:.8rem; color:var(--wf-primary); font-weight:500; display:flex; align-items:center; gap:3px; }
  .wf-dash-empty { text-align:center; padding:32px 16px; color:#5f6368; }
  .wf-dash-empty i { font-size:2rem; color:#dadce0; display:block; margin-bottom:8px; }
  .wf-dash-empty p { margin:0; font-size:.88rem; }
  .wf-modal-overlay { position:fixed; inset:0; z-index:100; background:rgba(32,33,36,.4); display:flex; align-items:center; justify-content:center; padding:16px; }
  .wf-modal-card { width:100%; max-width:420px; background:#fff; border-radius:8px; padding:16px; border:1px solid #e0e0e0; box-shadow:0 10px 30px rgba(0,0,0,.2); }
  .wf-modal-card label { font-size:.86rem; color:#202124; display:flex; gap:8px; align-items:center; }
  @media (max-width: 900px) { .wf-dash-grid { grid-template-columns:1fr; } .wf-dash-welcome { flex-direction:column; align-items:flex-start; } }
</style>

<%- include('../partials/shellEnd', { pageScript: '/workflow-assets/js/dashboard-personalization.js' }) %>