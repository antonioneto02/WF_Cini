<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Central de tarefas', href: '/tarefas' }, { label: '#' + payload.task.id }]
}) %>

<%
  const __fmtDateTime = (typeof fmtDateTime === 'function')
    ? fmtDateTime
    : function (value) {
        if (!value) return '-';
        const d = value instanceof Date ? value : new Date(value);
        if (Number.isNaN(d.getTime())) return '-';
        return d.toLocaleString('pt-BR', {
          timeZone: 'America/Sao_Paulo',
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
      };

  const statusBadge = (s) => {
    if (s === 'CONCLUIDA')    return 'wf-badge-green';
    if (s === 'EM_ANDAMENTO') return 'wf-badge-blue';
    return 'wf-badge-yellow';
  };
  const statusLabel = (s) => s === 'CONCLUIDA' ? 'Concluída' : s === 'EM_ANDAMENTO' ? 'Em andamento' : 'Pendente';
%>

<!-- Task header -->
<div class="wf-solic-header" style="margin-bottom:20px">
  <div style="display:flex;align-items:center;gap:12px">
    <a href="/tarefas" class="wf-btn-secondary" style="padding:6px 10px" title="Voltar"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h2 style="margin:0;font-size:1.15rem;font-weight:600;color:#202124">
        <%= payload.task.nome_etapa %> <span style="font-weight:400;color:#5f6368">#<%= payload.task.id %></span>
      </h2>
      <p style="margin:2px 0 0;font-size:.85rem;color:#5f6368">Processo: <strong><%= payload.task.processo_nome %></strong></p>
    </div>
  </div>
  <span class="<%= statusBadge(payload.task.status) %>" style="font-size:.85rem;padding:5px 14px">
    <%= payload.task.status_label || statusLabel(payload.task.status) %>
  </span>
</div>

<!-- Metadata -->
<div class="wf-solic-meta" style="margin-bottom:20px">
  <div class="wf-solic-meta-item">
    <span class="wf-solic-meta-label">Identificador</span>
    <span class="wf-solic-meta-value"><%= payload.task.identificador || '-' %></span>
  </div>
  <div class="wf-solic-meta-item">
    <span class="wf-solic-meta-label">Solicitante</span>
    <span class="wf-solic-meta-value"><%= payload.task.solicitante || '-' %></span>
  </div>
  <div class="wf-solic-meta-item">
    <span class="wf-solic-meta-label">Responsável</span>
    <span class="wf-solic-meta-value"><%= payload.task.responsavel || '-' %></span>
  </div>
  <div class="wf-solic-meta-item">
    <span class="wf-solic-meta-label">Data início</span>
    <span class="wf-solic-meta-value"><%= __fmtDateTime(payload.task.started_at || payload.task.created_at) %></span>
  </div>
  <div class="wf-solic-meta-item">
    <span class="wf-solic-meta-label">Status</span>
    <span class="wf-solic-meta-value"><span class="<%= statusBadge(payload.task.status) %>"><%= payload.task.status_label || statusLabel(payload.task.status) %></span></span>
  </div>
</div>

<!-- Tabs -->
  <div class="wf-tabs" style="margin-bottom:0;border-radius:8px 8px 0 0">
  <a href="#" class="wf-tab active" data-tab="form">Formulário</a>
  <a href="#" class="wf-tab" data-tab="history">Histórico</a>
  <a href="#" class="wf-tab" data-tab="comments">Comentários</a>
</div>

<!-- Formulario tab -->
<div class="wf-panel" id="tab-form" style="border-radius:0 0 8px 8px;margin-top:0">
  <form id="taskCompleteForm" data-task-id="<%= payload.task.id %>">
    <div id="dynamicFormRoot" style="display:grid;gap:14px;margin-bottom:16px"></div>

    <div style="margin-bottom:16px">
      <label style="display:block;font-size:.85rem;font-weight:500;margin-bottom:4px;color:#202124">Observação</label>
      <textarea name="observacao" rows="3" placeholder="Comentário da aprovação/rejeição"
        style="width:100%;padding:8px 12px;border:1px solid #dadce0;border-radius:6px;font-size:.9rem;resize:vertical"></textarea>
    </div>

    <div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;padding-top:12px;border-top:1px solid #e0e0e0">
      <button type="button" id="saveDraftBtn" class="wf-btn-secondary">
        <i class="bi bi-save"></i> Salvar rascunho
      </button>
      <button type="button" data-action="concluir" class="complete-btn wf-btn-danger">
        <i class="bi bi-x-circle"></i> Concluir tarefa
      </button>
      <button type="button" data-action="aprovar" class="complete-btn wf-btn-primary">
        <i class="bi bi-send"></i> Enviar para próxima etapa
      </button>
    </div>
  </form>
</div>

<!-- Comentarios tab -->
<div class="wf-panel" id="tab-comments" style="border-radius:0 0 8px 8px;margin-top:0;display:none">
  <div id="taskCommentsPanel" class="wf-comments-wrap" data-task-id="<%= payload.task.id %>" data-instance-id="<%= payload.task.instancia_processo_id %>">
    <div id="taskCommentsList" class="wf-comments-wrap">
      <% if (!comments || !comments.length) { %>
        <div class="wf-comment-item" id="taskCommentsEmptyState">
          <div class="wf-comment-meta">Sem comentários ainda</div>
          <div class="wf-comment-text">Se precisar alinhar aprovação, mencione alguém com @usuario.</div>
        </div>
      <% } %>
      <% (comments || []).forEach(function(item){ %>
        <div class="wf-comment-item">
          <div class="wf-comment-meta"><strong><%= item.autor %></strong> &middot; <%= __fmtDateTime(item.created_at) %></div>
          <div class="wf-comment-text"><%= item.mensagem %></div>
        </div>
      <% }) %>
    </div>

      <form id="taskCommentForm" class="wf-comment-form">
      <div class="wf-comment-mention-wrap">
        <textarea id="taskCommentInput" placeholder="Escreva um comentário (use @usuario para mencionar)"></textarea>
        <div id="taskCommentMentionSuggestions" class="wf-comment-mention-suggestions" style="display:none"></div>
      </div>
      <div style="display:flex;justify-content:flex-end;gap:8px">
        <button type="submit" class="wf-btn-primary" style="font-size:.85rem"><i class="bi bi-chat-dots"></i> Comentar</button>
      </div>
    </form>
  </div>
</div>

<!-- Historico tab -->
<div class="wf-panel" id="tab-history" style="border-radius:0 0 8px 8px;margin-top:0;display:none">
  <% if (!payload.history.length) { %>
    <div style="text-align:center;padding:32px;color:#5f6368">
      <i class="bi bi-clock-history" style="font-size:2rem;color:#dadce0"></i>
      <p style="margin:8px 0 0">Nenhum evento registrado.</p>
    </div>
  <% } else { %>
    <div class="wf-timeline">
      <% payload.history.forEach(function(item){ %>
        <div class="wf-timeline-item">
          <%
            let dotColor = '#5f6368';
            let dotIcon  = 'bi-circle-fill';
            if (item.tipo_evento === 'TASK_COMPLETED') { dotColor = '#1e8e3e'; dotIcon = 'bi-check-circle-fill'; }
            else if (item.tipo_evento === 'TASK_CREATED') { dotColor = '#1a73e8'; dotIcon = 'bi-plus-circle-fill'; }
            else if (item.tipo_evento === 'STARTED') { dotColor = '#e8a817'; dotIcon = 'bi-play-circle-fill'; }
            else if (item.tipo_evento === 'FINISHED') { dotColor = '#1e8e3e'; dotIcon = 'bi-flag-fill'; }
          %>
          <div class="wf-timeline-dot" style="color:<%= dotColor %>"><i class="bi <%= dotIcon %>"></i></div>
          <div class="wf-timeline-content">
            <strong><%= item.tipo_evento %></strong>
            <p><%= item.descricao || '-' %></p>
            <span style="font-size:.78rem;color:#80868b"><%= __fmtDateTime(item.created_at) %> &bull; <%= item.executor || 'sistema' %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
document.querySelectorAll('.wf-tab[data-tab]').forEach(function(tab) {
  tab.addEventListener('click', function(e) {
    e.preventDefault();
    document.querySelectorAll('.wf-tab[data-tab]').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    var target = this.getAttribute('data-tab');
    document.getElementById('tab-form').style.display = target === 'form' ? '' : 'none';
    document.getElementById('tab-history').style.display = target === 'history' ? '' : 'none';
    document.getElementById('tab-comments').style.display = target === 'comments' ? '' : 'none';
  });
});
</script>

<script id="taskDetailSeed" type="application/json"><%- JSON.stringify({
  task: payload.task,
  form: payload.form,
  responses: payload.responses,
  comments: comments || []
}) %></script>

<%- include('../partials/shellEnd', { pageScript: '/workflow-assets/js/task-detail.js' }) %>
