<%- include('../partials/shellStart', {
  pageTitle: 'Central de Tarefas',
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Central de Tarefas' }]
}) %>

<%
  const __fmtDateTime = (typeof fmtDateTime === 'function')
    ? fmtDateTime
    : function (value) {
        if (!value) return '-';
        const d = value instanceof Date ? value : new Date(value);
        if (Number.isNaN(d.getTime())) return '-';
        return d.toLocaleString('pt-BR', {
          timeZone: 'America/Sao_Paulo',
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
      };

  const __toEpochMs = (typeof toEpochMs === 'function')
    ? toEpochMs
    : function (value) {
        if (!value) return '';
        const d = value instanceof Date ? value : new Date(value);
        if (Number.isNaN(d.getTime())) return '';
        return String(d.getTime());
      };

  const currentStatus = filters.status || '';
%>

<!-- Page header -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
  <h2 style="margin:0;font-size:20px;font-weight:700;color:#202124">Central de Tarefas</h2>
  <span style="font-size:13px;color:#5f6368"><%= result.total %> tarefa(s)</span>
</div>

<!-- Fluig-style tabs -->
  <div class="wf-tabs">
  <a href="/tarefas" class="wf-tab <%= !currentStatus ? 'active' : '' %>">Todas</a>
  <a href="/tarefas?status=MINHAS_TAREFAS&processName=<%= encodeURIComponent(filters.processName || '') %>&search=<%= encodeURIComponent(filters.search || '') %>" class="wf-tab <%= currentStatus === 'MINHAS_TAREFAS' ? 'active' : '' %>">A concluir</a>
  <a href="/tarefas?status=EM_ANDAMENTO&processName=<%= encodeURIComponent(filters.processName || '') %>&search=<%= encodeURIComponent(filters.search || '') %>" class="wf-tab <%= currentStatus === 'EM_ANDAMENTO' ? 'active' : '' %>">Em andamento</a>
  <a href="/tarefas?status=CONCLUIDA&processName=<%= encodeURIComponent(filters.processName || '') %>&search=<%= encodeURIComponent(filters.search || '') %>" class="wf-tab <%= currentStatus === 'CONCLUIDA' ? 'active' : '' %>">Concluidas</a>
</div>

<!-- Filters -->
<div class="wf-filter-bar">
  <form id="taskFilterForm" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;width:100%">
    <input type="hidden" name="status" value="<%= filters.status %>" />
    <div style="min-width:160px">
      <label>Processo</label>
      <input name="processName" value="<%= filters.processName %>" placeholder="Nome do processo" />
    </div>
    <div style="min-width:120px">
      <label>Solicitacao</label>
      <input name="instanciaId" value="<%= filters.instanciaId %>" placeholder="ID da solicitação" />
    </div>
    <div style="min-width:140px">
      <label>Identificador</label>
      <input name="identificador" value="<%= filters.identificador %>" placeholder="Identificador" />
    </div>
    <div style="flex:1;min-width:200px">
      <label>Desc</label>
      <input name="desc" value="<%= filters.search %>" placeholder="Descrição do identificador" />
    </div>
    <div style="min-width:160px">
      <label>Data início</label>
      <input type="date" name="startDate" value="<%= filters.startDate %>" />
    </div>
    <div style="min-width:160px">
      <label>Data fim</label>
      <input type="date" name="endDate" value="<%= filters.endDate %>" />
    </div>
    
  </form>
</div>

<!-- Task list -->
<div class="wf-panel" style="padding:0;overflow:hidden">
  <table class="wf-table">
    <thead>
      <tr>
        <th>Processo</th>
        <th>Solicitacao</th>
        <th>desc</th>
        <th>Identificador</th>
        <th>Atividade</th>
        <th>Data</th>
        <th>Prazo (SLA)</th>
        <th>Status</th>
        <th style="text-align:right">Acao</th>
      </tr>
    </thead>
    <tbody>
      <% if (!result.data.length) { %>
        <tr>
          <td colspan="9" style="text-align:center;padding:40px;color:#5f6368">
            <i class="bi bi-inbox" style="font-size:32px;color:#dadce0;display:block;margin-bottom:8px"></i>
            Nenhuma tarefa encontrada para os filtros informados.
          </td>
        </tr>
      <% } %>
      <% result.data.forEach(function(task){ %>
        <tr>
          <td>
            <strong style="display:block"><%= task.processo_nome %></strong>
          </td>
          <td><span class="wf-badge wf-badge-blue">#<%= task.instancia_processo_id %></span></td>
          <td><%= task.processo_desc_iden || '-' %></td>
          <td><%= task.identificador || '-' %></td>
          <td><strong><%= task.nome_etapa %></strong></td>
          <td><%= __fmtDateTime(task.created_at) %></td>
          <td>
            <span class="sla-badge"
              data-created-at-ms="<%= __toEpochMs(task.created_at) %>"
              data-completed-at-ms="<%= __toEpochMs(task.completed_at) %>"
              data-status="<%= task.status || '' %>"
              data-sla-hours="<%= task.sla_horas || 24 %>">
            </span>
          </td>
          <td>
            <% const statusClass = task.status === 'CONCLUIDA' ? 'wf-badge-green' : (task.status === 'MINHAS_TAREFAS' ? 'wf-badge-yellow' : 'wf-badge-blue'); %>
            <span class="wf-badge <%= statusClass %>"><%= task.status_label || task.status %></span>
          </td>
          <td style="text-align:right">
            <a href="/tarefas/<%= task.id %>" class="wf-btn-primary" style="font-size:12px;padding:5px 14px">Abrir</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/shellEnd', { pageScript: '/workflow-assets/js/tasks-kanban.js' }) %>
