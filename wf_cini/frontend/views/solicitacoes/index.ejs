<%- include('../partials/shellStart', {
  pageTitle,
  pageDescription,
  user,
  currentPath,
  breadcrumbs: [{ label: 'Solicitacoes' }]
}) %>

<%
  const __fmtDateTime = (typeof fmtDateTime === 'function')
    ? fmtDateTime
    : function (value) {
        if (!value) return '-';
        const d = value instanceof Date ? value : new Date(value);
        if (Number.isNaN(d.getTime())) return '-';
        return d.toLocaleString('pt-BR', {
          timeZone: 'America/Sao_Paulo',
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
      };
%>

<div class="wf-panel mb-4">
  <form class="grid md:grid-cols-3 gap-2 items-end">
    <div>
      <label class="block text-xs font-semibold mb-1">Processo ID</label>
      <input name="processoId" value="<%= filters.processoId %>" class="w-full px-3 py-2 rounded-xl border border-slate-300" />
    </div>
    <div>
      <label class="block text-xs font-semibold mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 rounded-xl border border-slate-300">
        <option value="">Todos</option>
        <option value="EM_ANDAMENTO" <%= filters.status === 'EM_ANDAMENTO' ? 'selected' : '' %>>EM_ANDAMENTO</option>
        <option value="CONCLUIDA" <%= filters.status === 'CONCLUIDA' ? 'selected' : '' %>>CONCLUIDA</option>
      </select>
    </div>
    <button class="px-4 py-2 rounded-xl bg-ciniBlue text-white">Filtrar</button>
  </form>
</div>

<div class="wf-panel">
  <div class="overflow-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left border-b border-slate-200">
          <th class="py-2 pr-3">Numero da solicitacao</th>
          <th class="py-2 pr-3">Processo</th>
          <th class="py-2 pr-3">Solicitante</th>
          <th class="py-2 pr-3">Status</th>
          <th class="py-2 pr-3">Data inicio</th>
          <th class="py-2 pr-3">Atividade atual</th>
        </tr>
      </thead>
      <tbody>
        <% if (!result.data.length) { %>
          <tr><td colspan="6" class="py-4 text-slate-500">Nenhuma solicitacao encontrada.</td></tr>
        <% } %>
        <% result.data.forEach(function(item){ %>
          <tr class="border-b border-slate-100">
            <td class="py-3 pr-3 font-semibold">#<%= item.id %></td>
            <td class="py-3 pr-3"><%= item.processo_nome %> (v<%= item.versao %>)</td>
            <td class="py-3 pr-3"><%= item.solicitante || '-' %></td>
            <td class="py-3 pr-3"><span class="px-2 py-1 rounded-lg bg-slate-100"><%= item.status %></span></td>
            <td class="py-3 pr-3"><%= __fmtDateTime(item.started_at) %></td>
            <td class="py-3 pr-3"><%= item.current_element_id || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/shellEnd', { pageScript: '' }) %>
